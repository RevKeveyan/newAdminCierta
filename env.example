# Server Configuration
NODE_ENV=development
PORT=5000

# Database Configuration
MONGO_URI=mongodb+srv://rkeveyan:Vzgoletsgo2@adminka.5g0zdp4.mongodb.net/
MONGO_DB_NAME=Adminka

# Redis Configuration (Optional)
CACHE_ENABLED=false
REDIS_URL=redis://:redis123@localhost:6379
REDIS_PASSWORD=redis123

# JWT Configuration
JWT_SECRET=your_jwt_secret_here_change_this_in_production
JWT_EXPIRE=7d

# CORS Configuration (REQUIRED for security)
# Comma-separated list of allowed origins
# Must be exact matches - no wildcards
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Email Configuration (if using email features)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# AWS S3 Configuration (if using S3)
# Note: Files are now stored as PRIVATE - use signed URLs for access
# You can use either AWS_ACCESS_KEY or AWS_ACCESS_KEY_ID (both work)
AWS_ACCESS_KEY=your_aws_access_key
AWS_SECRET_KEY=your_aws_secret_key
# Alternative naming (also supported):
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_BUCKET=your_bucket_name

# Notification Service Configuration
NOTIFICATION_SERVICE_URL=http://localhost:5001
NOTIFICATION_SERVICE_TIMEOUT=30000
NOTIFICATION_SERVICE_ENABLED=true
# Internal token for communication between main server and notification service
# ⚠️ IMPORTANT: Must be the SAME in both server/.env and notifications/.env
# You can use any random secret string here, for example:
NOTIFICATION_INTERNAL_TOKEN=cierta-internal-secret-2024
# OR use INTERNAL_TOKEN (both work)
INTERNAL_TOKEN=cierta-internal-secret-2024
























