            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/stats/loads?from=2026-02-01&to=2026-02-28&grain=month&entityType=system",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "stats",
                "loads"
              ],
              "query": [
                {
                  "key": "from",
                  "value": "2026-02-01"
                },
                {
                  "key": "to",
                  "value": "2026-02-28"
                },
                {
                  "key": "grain",
                  "value": "month"
                },
                {
                  "key": "entityType",
                  "value": "system"
                }
              ]
            }
          }
        }
      ]
