    {
      "name": "Test Load Data",
      "item": [
        {
          "name": "Create Test Load (Listed Status)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const timestamp = Date.now();",
                  "pm.environment.set(\"testLoadOrderId\", `TEST-LOAD-${timestamp}`);"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200 || pm.response.code === 201) {",
                  "    const jsonData = pm.response.json();",
                  "    if (jsonData.data) {",
                  "        const loadId = jsonData.data._id || jsonData.data.id;",
                  "        if (loadId) {",
                  "            pm.environment.set(\"testLoadId\", loadId.toString());",
                  "        }",
                  "        if (jsonData.data.orderId) {",
                  "            pm.environment.set(\"testLoadOrderId\", jsonData.data.orderId);",
                  "        }",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"load\": {\n    \"orderId\": \"{{testLoadOrderId}}\",\n    \"status\": \"Listed\",\n    \"customer\": {\n      \"companyName\": \"Test Customer\",\n      \"email\": \"test-customer@example.com\",\n      \"type\": \"customer\"\n    },\n    \"type\": {\n      \"freight\": true,\n      \"vehicle\": false\n    },\n    \"freight\": {\n      \"shipment\": []\n    },\n    \"pickup\": {\n      \"locationName\": \"Test Pickup Location\",\n      \"address\": {\n        \"address\": \"123 Test St\",\n        \"city\": \"Test City\",\n        \"state\": \"CA\",\n        \"zipCode\": \"12345\"\n      },\n      \"contactPhone\": \"+1234567890\"\n    },\n    \"delivery\": {\n      \"locationName\": \"Test Delivery Location\",\n      \"address\": {\n        \"address\": \"456 Test Ave\",\n        \"city\": \"Test City\",\n        \"state\": \"CA\",\n        \"zipCode\": \"54321\"\n      },\n      \"contactPhone\": \"+1234567890\"\n    },\n    \"paymentTerms\": \"15\",\n    \"customerRate\": \"1000\",\n    \"carrierRate\": \"800\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/loads",
              "host": ["{{baseUrl}}"],
              "path": ["loads"]
            }
          },
          "description": "Создает тестовый Load со статусом 'Listed'. Минимальные данные для тестирования статистики."
        },
